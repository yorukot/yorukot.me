#!/usr/bin/env sh
set -eu

root_dir="$(git rev-parse --show-toplevel)"
cd "$root_dir"

if ! command -v pnpm >/dev/null 2>&1; then
    echo "pre-commit: pnpm is required but was not found in PATH." >&2
    exit 1
fi

echo "pre-commit: running lint"
pnpm lint

echo "pre-commit: running tests"
pnpm test

echo "pre-commit: running build"
pnpm build

if pnpm run | grep -q '^  prettier:write'; then
    echo "pre-commit: running prettier"
    pnpm prettier:write

    if ! git diff --quiet; then
        echo "Prettier formatted files. Please review and stage the changes, then commit again."
        exit 1
    fi
fi

echo "pre-commit: passed"
