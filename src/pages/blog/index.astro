---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import NewsletterSubscribe from '../../components/NewsletterSubscribe.astro';
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';
import { absoluteUrl, blogPostPath } from '../../lib/seo';

type BlogPost = CollectionEntry<'blog'>;

const posts: BlogPost[] = (await getCollection('blog')).sort((a: BlogPost, b: BlogPost) => {
    if (a.data.featured !== b.data.featured) {
        return Number(b.data.featured) - Number(a.data.featured);
    }

    return b.data.publish_date.getTime() - a.data.publish_date.getTime();
});

const formatDate = (date: Date) =>
    new Intl.DateTimeFormat('en', {
        year: 'numeric',
        month: 'short',
        day: '2-digit',
    }).format(date);

const title = `Blog | ${site.name}`;
const description = 'Notes, experiments, and the occasional write-up from Yorukot.';
const blogJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: absoluteUrl('/blog'),
    inLanguage: site.language,
    isPartOf: {
        '@type': 'WebSite',
        name: site.name,
        url: absoluteUrl('/'),
    },
};
const itemListJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `${site.name} Blog Posts`,
    itemListElement: posts.map((post: BlogPost, index: number) => ({
        '@type': 'ListItem',
        position: index + 1,
        url: absoluteUrl(blogPostPath(post.data.post_slug)),
        name: post.data.title,
    })),
};
---

<Layout
    title={title}
    description={description}
    canonicalPath="/blog"
    image="/blog/og.png"
    imageAlt="Yorukot blog social image"
    jsonLd={[blogJsonLd, itemListJsonLd]}
>
    <section class="blog-page border-t border-border px-6 py-16 text-text sm:px-10 sm:py-20">
        <div class="blog-shell space-y-12">
            <div class="space-y-4">
                <p class="font-mono text-sm uppercase tracking-[0.16em] text-primary">/blog</p>
                <h1 class="text-5xl font-bold uppercase tracking-[0.12em] text-text sm:text-6xl">Blog</h1>
                <p class="max-w-2xl text-lg leading-8 text-text/70">
                    Notes, experiments, and the occasional write-up.
                </p>
            </div>

            <NewsletterSubscribe variant="minimal" />

            {
                posts.length ? (
                    <div class="border-y border-border">
                        {posts.map((post: BlogPost) => (
                            <article class="blog-list-item border-t border-border py-8 first:border-t-0">
                                <div class="space-y-4">
                                    <div class="flex flex-wrap items-center gap-3 font-mono text-sm uppercase tracking-[0.12em] text-text/60">
                                        <time class="text-primary" datetime={post.data.publish_date.toISOString()}>
                                            {formatDate(post.data.publish_date)}
                                        </time>

                                        {post.data.featured && (
                                            <span class="inline-flex border border-primary px-2 py-1 text-xs text-primary">
                                                Featured
                                            </span>
                                        )}

                                        {post.data.tags.map((tag: string) => (
                                            <span class="border border-border px-2 py-1 text-xs text-text/60">
                                                #{tag}
                                            </span>
                                        ))}
                                    </div>

                                    <h2 class="text-xl font-bold leading-tight text-text sm:text-2xl">
                                        <a
                                            class="underline decoration-border underline-offset-4 transition-colors hover:text-primary hover:decoration-primary focus-visible:text-primary focus-visible:decoration-primary focus-visible:outline-none"
                                            href={blogPostPath(post.data.post_slug)}
                                        >
                                            {post.data.title}
                                        </a>
                                    </h2>

                                    <p class="text-base leading-7 text-text/70">
                                        {post.data.description}
                                    </p>
                                </div>
                            </article>
                        ))}
                    </div>
                ) : (
                    <p class="border-y border-border py-8 text-lg text-text/70">No posts yet.</p>
                )
            }
        </div>
    </section>
</Layout>

<style>
    .blog-shell {
        width: min(100%, 72rem);
        margin: 0 auto;
    }
</style>
