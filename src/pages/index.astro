---
import IcBaselineDiscord from '~icons/ic/baseline-discord';
import IcSharpEmail from '~icons/ic/sharp-email';
import MdiConsoleLine from '~icons/mdi/console-line';
import MdiGithub from '~icons/mdi/github';
import MdiHeart from '~icons/mdi/heart';
import MdiSourceBranch from '~icons/mdi/source-branch';
import MdiTelegram from '~icons/mdi/telegram';
import MdiWeb from '~icons/mdi/web';
import BoidsBackground from '../components/BoidsBackground.astro';
import { about } from '../data/about';
import { contact } from '../data/contact';
import { hero } from '../data/hero';
import { site } from '../data/site';
import { works } from '../data/works';
import Layout from '../layouts/Layout.astro';
import { absoluteAssetUrl, absoluteUrl } from '../lib/seo';

const interestIconMap = {
    openSource: MdiSourceBranch,
    terminal: MdiConsoleLine,
    web: MdiWeb,
};

const contactIconMap = {
    Email: IcSharpEmail,
    GitHub: MdiGithub,
    Discord: IcBaselineDiscord,
    Telegram: MdiTelegram,
};

type WorkItem = (typeof works.works)[number];
type ContactChannel = (typeof contact.channels)[number];

const homeJsonLd = [
    {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: site.name,
        url: absoluteUrl('/'),
        description: site.description,
        inLanguage: site.language,
        publisher: {
            '@type': 'Person',
            name: site.author,
            url: absoluteUrl('/'),
        },
    },
    {
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: site.author,
        url: absoluteUrl('/'),
        email: site.email,
        image: absoluteAssetUrl(site.defaultOgImage),
        sameAs: [
            site.social.github,
            site.social.telegram,
            site.social.youtube,
            site.social.kofi,
        ],
        knowsAbout: ['Open source', 'CLI', 'TUI', 'Backend development', 'Full-stack web'],
    },
];
---

<Layout
    description={site.description}
    canonicalPath="/"
    image={site.defaultOgImage}
    imageAlt="Yorukot open-source developer social image"
    jsonLd={homeJsonLd}
>
    <section class="hero-section relative isolate overflow-hidden px-6 py-8 sm:px-10 sm:py-10">
        <BoidsBackground />

        <div class="hero-content relative z-10 flex items-end">
            <div class="select-none space-y-4">
                <p class="hero-intro font-medium tracking-[0.12em] text-text">
                    <span data-hero-intro></span><span
                        class="hero-intro-caret ml-1 inline-block h-[1em] w-px translate-y-[0.12em] bg-primary opacity-0"
                        data-hero-intro-caret
                        aria-hidden="true"></span>
                </p>

                <p
                    class="hero-headline uppercase tracking-[0.26em] text-text font-extrabold"
                    data-random-clone-text
                >
                    <span data-random-clone-label>{hero.headline}</span>
                </p>
            </div>
        </div>
    </section>

    <section class="border-t border-border px-6 py-20 sm:px-10 sm:py-24" id="about" data-reveal-section>
        <div class="home-content flex flex-col gap-12 lg:flex-row lg:items-start lg:justify-between">
            <div class="space-y-5 lg:max-w-sm">
                <h1
                    class="about-reveal about-reveal-heading text-5xl uppercase text-text font-bold"
                    data-section-reveal
                >
                    <span>{about.heading}</span>
                </h1>
            </div>
            <div class="space-y-8 text-text lg:max-w-2xl">
                <div class="space-y-5 text-lg leading-8 text-text/80">
                    {about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                </div>

                <a
                    class="about-blog-link inline-flex border border-border px-4 py-3 font-mono text-sm uppercase tracking-[0.14em] text-primary no-underline transition-colors hover:border-primary hover:bg-primary hover:text-background focus-visible:border-primary focus-visible:bg-primary focus-visible:text-background focus-visible:outline-none"
                    href="/blog"
                >
                    Go to blog
                </a>

                <div class="grid grid-cols-[auto_1fr] gap-px border-y border-border bg-border text-sm uppercase tracking-[0.16em] text-text sm:grid-cols-[auto_1fr_auto_1fr_auto_1fr]">
                    {about.interests.map((interest) => (
                        <>
                            {(() => {
                                const Icon = interestIconMap[interest.icon];

                                return (
                                    <div class="flex min-h-14 items-center justify-center bg-background px-4 text-xl text-primary">
                                        <Icon aria-hidden="true" />
                                    </div>
                                );
                            })()}
                            <div class="flex min-h-14 items-center bg-background px-4">
                                <span>{interest.label}</span>
                            </div>
                        </>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <section class="border-t border-border px-6 py-20 sm:px-10 sm:py-24" id="software" data-reveal-section>
        <div class="home-content space-y-12">
            <div class="max-w-sm">
                <h2
                    class="about-reveal about-reveal-heading text-5xl uppercase text-text font-bold"
                    data-section-reveal
                >
                    <span>{works.heading}</span>
                </h2>
            </div>

            <div class="space-y-8 text-text">
                <p class="text-lg leading-8 text-text/80">
                    {works.intro}
                </p>

                <div class="grid border-y border-border bg-background">
                    {works.works.map((item: WorkItem) => (
                        <article class="work-reveal-row bg-background text-text" data-work-reveal>
                            <div class="space-y-4 px-0 py-5 sm:px-5">
                                <div class="flex items-start justify-between gap-4">
                                    <div class="font-mono text-sm text-primary">
                                        {item.id}
                                    </div>

                                    <span class="inline-flex shrink-0 border border-primary px-2 py-1 text-xs uppercase tracking-[0.14em] text-primary">
                                        {item.status}
                                    </span>
                                </div>

                                <div class="flex flex-wrap items-center gap-3">
                                    <h3 class="text-xl font-bold text-text">
                                        {'href' in item ? (
                                            <a
                                                class="underline decoration-border underline-offset-4 transition-colors hover:text-primary hover:decoration-primary focus-visible:text-primary focus-visible:decoration-primary focus-visible:outline-none"
                                                href={item.href}
                                                target={item.href.startsWith('http') ? '_blank' : undefined}
                                                rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
                                            >
                                                {item.title}
                                            </a>
                                        ) : (
                                            item.title
                                        )}
                                    </h3>
                                    <span class="border border-border px-2 py-1 text-xs uppercase tracking-[0.14em] text-text/70">
                                        {item.type}
                                    </span>
                                </div>
                            </div>

                            <div class="px-0 pb-5 sm:px-5">
                                <p class="text-base leading-7 text-text/70">
                                    {item.description}
                                </p>

                                <div class="mt-5 flex flex-wrap gap-2">
                                    {item.tags.map((tag) => (
                                        <span class="border border-border px-2 py-1 font-mono text-xs uppercase tracking-[0.12em] text-text/60">
                                            {tag}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        </article>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <section class="border-t border-border px-6 py-20 sm:px-10 sm:py-24" id="contact" data-reveal-section>
        <div class="home-content space-y-12">
            <div class="max-w-sm">
                <h2
                    class="about-reveal about-reveal-heading text-5xl uppercase text-text font-bold"
                    data-section-reveal
                >
                    <span>{contact.heading}</span>
                </h2>
            </div>

            <div class="space-y-8 text-text">
                <p class="max-w-3xl text-lg leading-8 text-text/80">
                    {contact.intro}
                </p>

                <div class="grid gap-px border-y border-border bg-border lg:grid-cols-[minmax(0,1.15fr)_minmax(20rem,0.85fr)]">
                    <a
                        class="donate-panel group relative isolate grid min-h-72 overflow-hidden bg-background p-6 text-text no-underline transition-colors focus-visible:outline-none sm:p-8 lg:grid-cols-[7rem_1fr] lg:gap-5"
                        href={contact.donate.href}
                        target="_blank"
                        rel="noreferrer"
                    >
                        <span class="donate-panel-logo" aria-hidden="true">
                            <MdiHeart />
                        </span>

                        <div class="relative z-10 font-mono text-sm uppercase tracking-[0.14em] text-primary transition-colors group-hover:text-background group-focus-visible:text-background">
                            /{contact.donate.label}
                        </div>

                        <div class="relative z-10 mt-8 space-y-5 lg:mt-0">
                            <h3 class="max-w-xl text-4xl font-bold uppercase text-current transition-colors sm:text-5xl">
                                {contact.donate.title}
                            </h3>
                            <p class="max-w-xl text-lg leading-8 text-text/70 transition-colors group-hover:text-background/70 group-focus-visible:text-background/70">
                                {contact.donate.description}
                            </p>
                            <div class="inline-flex border border-border px-3 py-2 font-mono text-sm text-primary transition-colors group-hover:border-background group-hover:text-background group-focus-visible:border-background group-focus-visible:text-background">
                                Ko-fi
                            </div>
                        </div>
                    </a>

                    <div class="grid gap-px bg-border">
                        {contact.channels.map((item: ContactChannel) => {
                            const Icon = contactIconMap[item.label];

                            return (
                                <a
                                    class="contact-channel group relative isolate overflow-hidden bg-background p-5 text-text no-underline transition-colors focus-visible:outline-none sm:p-6"
                                    href={item.href}
                                    target={item.href.startsWith('mailto:') ? undefined : '_blank'}
                                    rel={item.href.startsWith('mailto:') ? undefined : 'noreferrer'}
                                >
                                    <span class="contact-channel-logo" aria-hidden="true">
                                        <Icon />
                                    </span>

                                    <div class="relative z-10 flex items-center justify-between gap-6">
                                        <div class="flex flex-wrap items-center gap-3">
                                            <h3 class="text-xl font-bold text-current transition-colors">
                                                {item.label}
                                            </h3>
                                            <span class="font-mono text-sm text-primary transition-colors group-hover:text-background group-focus-visible:text-background">
                                                {item.value}
                                            </span>
                                        </div>
                                    </div>
                                </a>
                            );
                        })}
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .home-content {
        width: 100%;
        max-width: 72rem;
        margin-inline: auto;
    }

    .hero-section {
        min-height: calc(100vh - 4rem);
    }

    .hero-content {
        min-height: calc(100vh - 9.5rem);
    }

    @media (min-width: 800px) {
        .hero-section {
            min-height: calc(100vh - 6.5rem);
        }

        .hero-content {
            min-height: calc(100vh - 12rem);
        }
    }

    .hero-headline {
        font-size: clamp(1rem, 9vw, 6rem);
        line-height: 1;
    }

    .hero-intro {
        font-size: clamp(1rem, 3vw, 1.875rem);
        line-height: 1.2;
    }

    .hero-intro-caret.is-visible {
        opacity: 1;
        animation: hero-intro-caret-blink 700ms steps(1) infinite;
    }

    .donate-panel:hover,
    .donate-panel:focus-visible {
        background: var(--color-text);
        color: var(--color-background);
    }

    .donate-panel-logo {
        position: absolute;
        right: 1.5rem;
        bottom: -1rem;
        z-index: 0;
        color: var(--color-background);
        font-size: 12rem;
        line-height: 1;
        opacity: 0;
        pointer-events: none;
        transform: translateX(1rem) rotate(-8deg);
        transition:
            opacity 420ms ease-out,
            transform 420ms ease-out;
        mask-image: linear-gradient(90deg, transparent 0%, black 100%);
        -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 100%);
    }

    .donate-panel:hover .donate-panel-logo,
    .donate-panel:focus-visible .donate-panel-logo {
        opacity: 0.16;
        transform: translateX(0) rotate(-8deg);
    }

    .contact-channel-logo {
        position: absolute;
        top: 50%;
        right: 1.5rem;
        z-index: 0;
        color: var(--color-background);
        font-size: 7rem;
        line-height: 1;
        opacity: 0;
        pointer-events: none;
        transform: translateY(-50%);
        transition:
            opacity 420ms ease-out,
            transform 420ms ease-out;
        mask-image: linear-gradient(90deg, transparent 0%, black 100%);
        -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 100%);
    }

    .contact-channel:hover,
    .contact-channel:focus-visible {
        background: var(--color-text);
        color: var(--color-background);
    }

    .contact-channel:hover .contact-channel-logo,
    .contact-channel:focus-visible .contact-channel-logo {
        opacity: 0.18;
        transform: translateY(-50%) translateX(-0.25rem);
    }

    .about-reveal {
        position: relative;
        display: block;
        overflow: hidden;
        color: var(--color-text);
        transition: color 300ms ease-out var(--about-reveal-delay, 0ms);
    }

    .about-reveal::before {
        content: "";
        position: absolute;
        inset: 0;
        transform: scaleX(0);
        transform-origin: left;
        background: var(--color-text);
        transition: transform 520ms ease-out var(--about-reveal-delay, 0ms);
    }

    .about-reveal > span {
        position: relative;
        z-index: 1;
    }

    .about-reveal-heading {
        width: fit-content;
        padding: 0.08em 0.14em;
        margin-inline: -0.14em;
    }

    .about-reveal.is-visible {
        color: var(--color-background);
    }

    .about-reveal.is-visible::before {
        transform: scaleX(1);
    }

    .work-reveal-row {
        border-top: 1px solid var(--color-border);
        opacity: 0;
        transform: translateX(2rem);
    }

    .work-reveal-row:first-child {
        border-top: 0;
    }

    @media (prefers-reduced-motion: reduce) {
        .about-reveal,
        .about-reveal::before {
            transition-duration: 0ms;
            transition-delay: 0ms;
        }

        .work-reveal-row {
            opacity: 1;
            transform: none;
        }
    }

    @keyframes hero-intro-caret-blink {
        50% {
            opacity: 0;
        }
    }
</style>

<script>
    import { animate, onScroll, splitText, utils } from 'animejs';
    import { hero } from '../data/hero';

    const intro = document.querySelector('[data-hero-intro]');
    const introCaret = document.querySelector('[data-hero-intro-caret]');
    const label = document.querySelector('[data-random-clone-label]');
    const revealSections = document.querySelectorAll('[data-reveal-section]');
    const workRevealItems = document.querySelectorAll('[data-work-reveal]');

    revealSections.forEach((section) => {
        const revealItems = section.querySelectorAll('[data-section-reveal]');

        if (!(section instanceof HTMLElement) || !revealItems.length) {
            return;
        }

        const showRevealItems = () => {
            revealItems.forEach((item) => {
                item.classList.add('is-visible');
            });
        };

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            showRevealItems();
        } else if ('IntersectionObserver' in window) {
            const revealObserver = new IntersectionObserver(
                (entries) => {
                    if (entries.some((entry) => entry.isIntersecting)) {
                        showRevealItems();
                        revealObserver.disconnect();
                    }
                },
                {
                    threshold: 0.35,
                },
            );

            revealObserver.observe(section);
        } else {
            showRevealItems();
        }
    });

    if (workRevealItems.length) {
        const showWorkRevealItem = (item: Element) => {
            if (!(item instanceof HTMLElement)) {
                return;
            }

            if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                item.style.opacity = '1';
                item.style.transform = 'translateX(0rem)';
                return;
            }

            animate(item, {
                x: ['3rem', '0rem'],
                opacity: 1,
                duration: 360,
                ease: 'out(3)',
            });
        };

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            workRevealItems.forEach(showWorkRevealItem);
        } else {
            workRevealItems.forEach((item) => {
                if (!(item instanceof HTMLElement)) {
                    return;
                }

                animate(item, {
                    x: ['3rem', '0rem'],
                    opacity: 1,
                    duration: 360,
                    ease: 'out(3)',
                    autoplay: onScroll({
                        target: item,
                        enter: { target: 'top', container: '60%' },
                        leave: { target: 'bottom', container: 'top' },
                        repeat: false,
                    }),
                });
            });
        }
    }

    if (intro instanceof HTMLElement) {
        const introRoles = hero.introRoles;
        const introPrefix = hero.introPrefix;
        const typewriterState = { count: 0 };
        let introTimeoutId: number | undefined;
        let previousRole: (typeof introRoles)[number] | undefined;

        intro.textContent = '';

        if (introCaret instanceof HTMLElement) {
            introCaret.classList.add('is-visible');
        }

        const pickIntroRole = () => {
            const availableRoles = introRoles.filter((role) => role !== previousRole);
            const role = availableRoles[utils.random(0, availableRoles.length - 1)];
            previousRole = role;
            return role;
        };

        const createIntroMessage = () => {
            const role = pickIntroRole();
            return `${introPrefix} ${role.article} ${role.label} and`;
        };

        const typeIntroMessage = (message: string, startIndex = introPrefix.length) => {
            typewriterState.count = startIndex;
            intro.textContent = message.slice(0, startIndex);

            animate(typewriterState, {
                count: message.length,
                duration: (message.length - startIndex) * 80,
                ease: 'linear',
                onUpdate: () => {
                    intro.textContent = message.slice(0, Math.floor(typewriterState.count));
                },
                onComplete: () => {
                    intro.textContent = message;
                    introTimeoutId = window.setTimeout(() => {
                        eraseIntroMessage(message);
                    }, 2600);
                },
            });
        };

        const eraseIntroMessage = (message: string) => {
            typewriterState.count = message.length;

            animate(typewriterState, {
                count: introPrefix.length,
                duration: (message.length - introPrefix.length) * 35,
                ease: 'linear',
                onUpdate: () => {
                    intro.textContent = message.slice(0, Math.ceil(typewriterState.count));
                },
                onComplete: () => {
                    intro.textContent = introPrefix;
                    introTimeoutId = window.setTimeout(() => {
                        typeIntroMessage(createIntroMessage());
                    }, 400);
                },
            });
        };

        typeIntroMessage(createIntroMessage(), 0);

        window.addEventListener(
            'pagehide',
            () => {
                window.clearTimeout(introTimeoutId);
            },
            { once: true },
        );
    }

    if (label instanceof HTMLElement) {
        const { chars } = splitText(label, {
            chars: {
                wrap: 'clip',
                clone: 'bottom',
            },
        });

        const activeChars = new WeakSet();
        const primaryChars = new WeakSet();
        const cooldownUntil = new WeakMap();
        const animatableChars = chars.filter((char) => char.textContent?.trim());
        const directions = hero.cloneDirections;
        let timeoutId: number | undefined;

        animatableChars.forEach((char) => {
            char.style.color = 'hsl(0 0% 100%)';
        });

        const triggerRandomClone = () => {
            const now = Date.now();
            const availableChars = animatableChars.filter(
                (char) => !activeChars.has(char) && (cooldownUntil.get(char) ?? 0) <= now,
            );
            const nextChar = availableChars.length
                ? utils.randomPick(availableChars)
                : null;

            if (nextChar) {
                activeChars.add(nextChar);

                const nextClone = nextChar.children[1];
                const direction = directions[utils.random(0, directions.length - 1)];

                if (nextClone instanceof HTMLElement) {
                    nextClone.style.top = direction.top;
                    nextClone.style.left = direction.left;
                }

                const isPrimary = primaryChars.has(nextChar);
                const nextColor = isPrimary ? 'hsl(0 0% 100%)' : 'var(--primary)';

                if (nextClone instanceof HTMLElement) {
                    nextClone.style.color = nextColor;
                }

                animate(nextChar, {
                    x: direction.x,
                    y: direction.y,
                    duration: utils.random(700, 1200),
                    ease: 'inOut(2)',
                    onComplete: () => {
                        nextChar.style.transform = 'translateX(0%) translateY(0%)';
                        nextChar.style.color = nextColor;

                        if (isPrimary) {
                            primaryChars.delete(nextChar);
                        } else {
                            primaryChars.add(nextChar);
                        }

                        if (nextClone instanceof HTMLElement) {
                            nextClone.style.color = '';
                        }

                        cooldownUntil.set(nextChar, Date.now() + utils.random(1800, 3200));
                        activeChars.delete(nextChar);
                    },
                });
            }

            timeoutId = window.setTimeout(
                triggerRandomClone,
                utils.random(1400, 2400),
            );
        };

        timeoutId = window.setTimeout(triggerRandomClone, utils.random(900, 1600));

        window.addEventListener(
            'pagehide',
            () => {
                window.clearTimeout(timeoutId);
            },
            { once: true },
        );
    }
</script>
