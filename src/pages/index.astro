---
import BoidsBackground from '../components/BoidsBackground.astro';
import { about } from '../data/about';
import { hero } from '../data/hero';
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <section class="relative isolate min-h-[calc(100vh-6.5rem)] overflow-hidden px-6 py-8 sm:px-10 sm:py-10">
        <BoidsBackground />

        <div class="relative z-10 flex min-h-[calc(100vh-12rem)] items-end">
            <div class="select-none space-y-4">
                <p class="text-xl font-medium tracking-[0.12em] text-text sm:text-2xl lg:text-3xl">
                    <span data-hero-intro></span><span
                        class="hero-intro-caret ml-1 inline-block h-[1em] w-px translate-y-[0.12em] bg-primary opacity-0"
                        data-hero-intro-caret
                        aria-hidden="true"></span>
                </p>

                <p
                    class="text-6xl uppercase tracking-[0.26em] text-text sm:text-7xl lg:text-8xl font-extrabold"
                    data-random-clone-text
                >
                    <span data-random-clone-label>{hero.headline}</span>
                </p>
            </div>
        </div>
    </section>

    <section class="border-t border-border px-6 py-20 sm:px-10 sm:py-24" id="about" data-about-section>
        <div class="mx-auto flex max-w-6xl flex-col gap-12 lg:flex-row lg:items-start lg:justify-between">
            <div class="max-w-sm space-y-5">
                <h1
                    class="about-reveal about-reveal-heading text-5xl uppercase text-text font-bold"
                    data-about-reveal
                >
                    <span>{about.heading}</span>
                </h1>
            </div>
            <div class="max-w-2xl space-y-8 text-text">
                <div class="space-y-5 text-lg leading-8 text-text/80">
                    {about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                </div>

                <div class="grid gap-px bg-border text-sm uppercase tracking-[0.16em] text-text sm:grid-cols-3">
                    {about.interests.map((interest, index) => (
                        <div
                            class="about-reveal about-reveal-cell bg-background p-4"
                            data-about-reveal
                            style={`--about-reveal-delay: ${180 + index * 100}ms`}
                        >
                            <span>{interest}</span>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .hero-intro-caret.is-visible {
        opacity: 1;
        animation: hero-intro-caret-blink 700ms steps(1) infinite;
    }

    .about-reveal {
        position: relative;
        display: block;
        overflow: hidden;
        color: var(--color-text);
        transition: color 300ms ease-out var(--about-reveal-delay, 0ms);
    }

    .about-reveal::before {
        content: "";
        position: absolute;
        inset: 0;
        transform: scaleX(0);
        transform-origin: left;
        background: var(--color-text);
        transition: transform 520ms ease-out var(--about-reveal-delay, 0ms);
    }

    .about-reveal > span {
        position: relative;
        z-index: 1;
    }

    .about-reveal-heading {
        width: fit-content;
        padding: 0.08em 0.14em;
        margin-inline: -0.14em;
    }

    .about-reveal-cell {
        min-height: 100%;
    }

    .about-reveal.is-visible {
        color: var(--color-background);
    }

    .about-reveal.is-visible::before {
        transform: scaleX(1);
    }

    @media (prefers-reduced-motion: reduce) {
        .about-reveal,
        .about-reveal::before {
            transition-duration: 0ms;
            transition-delay: 0ms;
        }
    }

    @keyframes hero-intro-caret-blink {
        50% {
            opacity: 0;
        }
    }
</style>

<script>
    import { animate, splitText, utils } from 'animejs';
    import { hero } from '../data/hero';

    const intro = document.querySelector('[data-hero-intro]');
    const introCaret = document.querySelector('[data-hero-intro-caret]');
    const label = document.querySelector('[data-random-clone-label]');
    const aboutSection = document.querySelector('[data-about-section]');
    const aboutRevealItems = document.querySelectorAll('[data-about-reveal]');

    if (aboutSection instanceof HTMLElement && aboutRevealItems.length) {
        const showAboutReveal = () => {
            aboutRevealItems.forEach((item) => {
                item.classList.add('is-visible');
            });
        };

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            showAboutReveal();
        } else if ('IntersectionObserver' in window) {
            const aboutObserver = new IntersectionObserver(
                (entries) => {
                    if (entries.some((entry) => entry.isIntersecting)) {
                        showAboutReveal();
                        aboutObserver.disconnect();
                    }
                },
                {
                    threshold: 0.35,
                },
            );

            aboutObserver.observe(aboutSection);
        } else {
            showAboutReveal();
        }
    }

    if (intro instanceof HTMLElement) {
        const introRoles = hero.introRoles;
        const introPrefix = hero.introPrefix;
        const typewriterState = { count: 0 };
        let introTimeoutId: number | undefined;
        let previousRole: (typeof introRoles)[number] | undefined;

        intro.textContent = '';

        if (introCaret instanceof HTMLElement) {
            introCaret.classList.add('is-visible');
        }

        const pickIntroRole = () => {
            const availableRoles = introRoles.filter((role) => role !== previousRole);
            const role = availableRoles[utils.random(0, availableRoles.length - 1)];
            previousRole = role;
            return role;
        };

        const createIntroMessage = () => {
            const role = pickIntroRole();
            return `${introPrefix} ${role.article} ${role.label} and`;
        };

        const typeIntroMessage = (message: string, startIndex = introPrefix.length) => {
            typewriterState.count = startIndex;
            intro.textContent = message.slice(0, startIndex);

            animate(typewriterState, {
                count: message.length,
                duration: (message.length - startIndex) * 80,
                ease: 'linear',
                onUpdate: () => {
                    intro.textContent = message.slice(0, Math.floor(typewriterState.count));
                },
                onComplete: () => {
                    intro.textContent = message;
                    introTimeoutId = window.setTimeout(() => {
                        eraseIntroMessage(message);
                    }, 2600);
                },
            });
        };

        const eraseIntroMessage = (message: string) => {
            typewriterState.count = message.length;

            animate(typewriterState, {
                count: introPrefix.length,
                duration: (message.length - introPrefix.length) * 35,
                ease: 'linear',
                onUpdate: () => {
                    intro.textContent = message.slice(0, Math.ceil(typewriterState.count));
                },
                onComplete: () => {
                    intro.textContent = introPrefix;
                    introTimeoutId = window.setTimeout(() => {
                        typeIntroMessage(createIntroMessage());
                    }, 400);
                },
            });
        };

        typeIntroMessage(createIntroMessage(), 0);

        window.addEventListener(
            'pagehide',
            () => {
                window.clearTimeout(introTimeoutId);
            },
            { once: true },
        );
    }

    if (label instanceof HTMLElement) {
        const { chars } = splitText(label, {
            chars: {
                wrap: 'clip',
                clone: 'bottom',
            },
        });

        const activeChars = new WeakSet();
        const primaryChars = new WeakSet();
        const cooldownUntil = new WeakMap();
        const animatableChars = chars.filter((char) => char.textContent?.trim());
        const directions = hero.cloneDirections;
        let timeoutId: number | undefined;

        animatableChars.forEach((char) => {
            char.style.color = 'hsl(0 0% 100%)';
        });

        const triggerRandomClone = () => {
            const now = Date.now();
            const availableChars = animatableChars.filter(
                (char) => !activeChars.has(char) && (cooldownUntil.get(char) ?? 0) <= now,
            );
            const nextChar = availableChars.length
                ? utils.randomPick(availableChars)
                : null;

            if (nextChar) {
                activeChars.add(nextChar);

                const nextClone = nextChar.children[1];
                const direction = directions[utils.random(0, directions.length - 1)];

                if (nextClone instanceof HTMLElement) {
                    nextClone.style.top = direction.top;
                    nextClone.style.left = direction.left;
                }

                const isPrimary = primaryChars.has(nextChar);
                const nextColor = isPrimary ? 'hsl(0 0% 100%)' : 'var(--primary)';

                if (nextClone instanceof HTMLElement) {
                    nextClone.style.color = nextColor;
                }

                animate(nextChar, {
                    x: direction.x,
                    y: direction.y,
                    duration: utils.random(700, 1200),
                    ease: 'inOut(2)',
                    onComplete: () => {
                        nextChar.style.transform = 'translateX(0%) translateY(0%)';
                        nextChar.style.color = nextColor;

                        if (isPrimary) {
                            primaryChars.delete(nextChar);
                        } else {
                            primaryChars.add(nextChar);
                        }

                        if (nextClone instanceof HTMLElement) {
                            nextClone.style.color = '';
                        }

                        cooldownUntil.set(nextChar, Date.now() + utils.random(1800, 3200));
                        activeChars.delete(nextChar);
                    },
                });
            }

            timeoutId = window.setTimeout(
                triggerRandomClone,
                utils.random(1400, 2400),
            );
        };

        timeoutId = window.setTimeout(triggerRandomClone, utils.random(900, 1600));

        window.addEventListener(
            'pagehide',
            () => {
                window.clearTimeout(timeoutId);
            },
            { once: true },
        );
    }
</script>
