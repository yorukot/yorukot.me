---
import BoidsBackground from '../components/BoidsBackground.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <section class="relative isolate min-h-[calc(100vh-6.5rem)] overflow-hidden px-6 py-8 sm:px-10 sm:py-10">
        <BoidsBackground />

        <div class="relative z-10 flex min-h-[calc(100vh-12rem)] items-end">
            <div class="select-none space-y-4">
                <p class="text-xl font-medium tracking-[0.12em] text-text sm:text-2xl lg:text-3xl">
                    <span data-hero-intro data-typewriter-text="This is Yorukot,"></span><span
                        class="hero-intro-caret ml-1 inline-block h-[1em] w-px translate-y-[0.12em] bg-primary opacity-0"
                        data-hero-intro-caret
                        aria-hidden="true"></span>
                </p>

                <p
                    class="text-6xl uppercase tracking-[0.26em] text-text sm:text-7xl lg:text-8xl font-extrabold"
                    data-random-clone-text
                >
                    <span data-random-clone-label>Open-source developer</span>
                </p>
            </div>
        </div>
    </section>

    <section class="border-t border-border px-6 py-20 sm:px-10 sm:py-24" id="about">
        <div class="mx-auto flex max-w-6xl flex-col gap-12 lg:flex-row lg:items-start lg:justify-between">
            <div class="max-w-sm space-y-5">
                <h1 class="text-5xl uppercase text-text font-bold">Who am I</h1>
            </div>
        </div>
    </section>
</Layout>

<style>
    .hero-intro-caret.is-visible {
        opacity: 1;
        animation: hero-intro-caret-blink 700ms steps(1) infinite;
    }

    @keyframes hero-intro-caret-blink {
        50% {
            opacity: 0;
        }
    }
</style>

<script>
    import { animate, splitText, utils } from 'animejs';

    const intro = document.querySelector('[data-hero-intro]');
    const introCaret = document.querySelector('[data-hero-intro-caret]');
    const label = document.querySelector('[data-random-clone-label]');

    if (intro instanceof HTMLElement) {
        const message = intro.dataset.typewriterText ?? '';
        const typewriterState = { count: 0 };

        intro.textContent = '';

        if (introCaret instanceof HTMLElement) {
            introCaret.classList.add('is-visible');
        }

        animate(typewriterState, {
            count: message.length,
            duration: message.length * 80,
            ease: 'linear',
            onUpdate: () => {
                intro.textContent = message.slice(0, Math.floor(typewriterState.count));
            },
            onComplete: () => {
                intro.textContent = message;

                window.setTimeout(() => {
                    if (introCaret instanceof HTMLElement) {
                        introCaret.classList.remove('is-visible');
                    }
                }, 1200);
            },
        });
    }

    if (label instanceof HTMLElement) {
        const { chars } = splitText(label, {
            chars: {
                wrap: 'clip',
                clone: 'bottom',
            },
        });

        const activeChars = new WeakSet();
        const primaryChars = new WeakSet();
        const cooldownUntil = new WeakMap();
        const animatableChars = chars.filter((char) => char.textContent?.trim());
        type CloneDirection = {
            x: string;
            y: string;
            top: string;
            left: string;
        };

        const directions: CloneDirection[] = [
            { x: '0%', y: '100%', top: '-100%', left: '0%' },
            { x: '-100%', y: '0%', top: '0%', left: '100%' },
            { x: '0%', y: '-100%', top: '100%', left: '0%' },
            { x: '100%', y: '0%', top: '0%', left: '-100%' },
        ];
        let timeoutId: number | undefined;

        animatableChars.forEach((char) => {
            char.style.color = 'hsl(0 0% 100%)';
        });

        const triggerRandomClone = () => {
            const now = Date.now();
            const availableChars = animatableChars.filter(
                (char) => !activeChars.has(char) && (cooldownUntil.get(char) ?? 0) <= now,
            );
            const nextChar = availableChars.length
                ? utils.randomPick(availableChars)
                : null;

            if (nextChar) {
                activeChars.add(nextChar);

                const nextClone = nextChar.children[1];
                const direction = directions[utils.random(0, directions.length - 1)];

                if (nextClone instanceof HTMLElement) {
                    nextClone.style.top = direction.top;
                    nextClone.style.left = direction.left;
                }

                const isPrimary = primaryChars.has(nextChar);
                const nextColor = isPrimary ? 'hsl(0 0% 100%)' : 'var(--primary)';

                if (nextClone instanceof HTMLElement) {
                    nextClone.style.color = nextColor;
                }

                animate(nextChar, {
                    x: direction.x,
                    y: direction.y,
                    duration: utils.random(700, 1200),
                    ease: 'inOut(2)',
                    onComplete: () => {
                        nextChar.style.transform = 'translateX(0%) translateY(0%)';
                        nextChar.style.color = nextColor;

                        if (isPrimary) {
                            primaryChars.delete(nextChar);
                        } else {
                            primaryChars.add(nextChar);
                        }

                        if (nextClone instanceof HTMLElement) {
                            nextClone.style.color = '';
                        }

                        cooldownUntil.set(nextChar, Date.now() + utils.random(1800, 3200));
                        activeChars.delete(nextChar);
                    },
                });
            }

            timeoutId = window.setTimeout(
                triggerRandomClone,
                utils.random(1400, 2400),
            );
        };

        timeoutId = window.setTimeout(triggerRandomClone, utils.random(900, 1600));

        window.addEventListener(
            'pagehide',
            () => {
                window.clearTimeout(timeoutId);
            },
            { once: true },
        );
    }
</script>
