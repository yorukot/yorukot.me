<div class="boids-background" aria-hidden="true" data-boids-root></div>

<script>
    import { mountBoids } from '../scripts/boids';

    const root = document.querySelector('[data-boids-root]');

    if (root instanceof HTMLElement) {
        const cleanup = mountBoids(root);

        window.addEventListener(
            'pagehide',
            () => {
                cleanup();
            },
            { once: true },
        );
    }
</script>

<style>
    .boids-background {
        position: absolute;
        inset: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .boids-background :global(canvas) {
        display: block;
        width: 100%;
        height: 100%;
        opacity: 0.7;
        mix-blend-mode: screen;
    }
</style>
