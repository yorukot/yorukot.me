---
import { footerLinks, navigationItems } from "../data/navigation";
import { site } from "../data/site";

const year = new Date().getFullYear();
---

<footer class="footer border-t border-text bg-text px-6 py-16 text-background sm:px-10 sm:py-20">
    <div class="footer-content space-y-10">
        <div class="grid gap-8 lg:items-start">
            <div class="space-y-4">
                <h2 class="text-5xl font-bold uppercase tracking-[0.18em] text-background">
                    {site.name}
                </h2>
                <p class="max-w-2xl text-lg leading-8 text-background/70">
                    Welcome to my corner of internet.
                </p>
            </div>
        </div>

        <div class="grid gap-8 border-b border-background/30 pb-10 lg:grid-cols-2">
            <nav class="flex flex-wrap gap-x-8 gap-y-4" aria-label="Footer navigation">
                {navigationItems.map((item) => (
                    <a
                        class="footer-link scramble-link"
                        href={item.href}
                        target={item.href.startsWith('http') ? '_blank' : undefined}
                        rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
                    >
                        <span class="scramble-link-label" data-scramble-text>{item.label}</span>
                    </a>
                ))}
            </nav>

            <nav class="flex flex-wrap gap-x-8 gap-y-4 lg:justify-end" aria-label="Footer links">
                {footerLinks.map((item) => (
                    <a
                        class="footer-link scramble-link"
                        href={item.href}
                        target={item.href.startsWith('mailto:') ? undefined : '_blank'}
                        rel={item.href.startsWith('mailto:') ? undefined : 'noreferrer'}
                    >
                        <span class="scramble-link-label" data-scramble-text>{item.label}</span>
                    </a>
                ))}
            </nav>
        </div>

        <div class="flex flex-col gap-3 font-mono text-sm uppercase tracking-[0.14em] text-background/60 sm:flex-row sm:items-center sm:justify-between">
            <span>Built in Taiwan</span>
            <span>Open source when possible</span>
            <span>{year}</span>
        </div>
    </div>
</footer>

<style>
    .footer-content {
        width: 100%;
    }

    .footer-link {
        color: var(--color-background);
        font-size: 1rem;
        font-weight: 700;
        white-space: nowrap;
        text-decoration: none;
        transition:
            color 180ms ease-out,
            text-decoration-color 180ms ease-out;
    }

    .footer-link:hover,
    .footer-link:focus-visible {
        color: var(--color-background);
        text-decoration-color: var(--color-primary);
        outline: none;
    }

</style>
