---
import MdiKeyboardArrowRight from "~icons/mdi/keyboard-arrow-right";
---

<header
    class="border-b border-border bg-background tracking-[0.08em] backdrop-blur text-text"
>
    <div class="h-24">
        <div class="flex justify-between h-full">
            <div class="flex">
                <div
                    class="w-24 h-24 border-r border-border justify-center items-center flex"
                >
                    temp
                </div>

                <div
                    class="flex flex-col h-full border-r text-lg border-border"
                >
                    <div
                        class="flex-1 flex items-center border-border border-b px-5"
                    >
                        Try with ssh below
                    </div>
                    <div class="flex-1 flex items-center px-5">
                        $ ssh yorukot.me
                    </div>
                </div>
            </div>
            <div class="h-full flex items-stretch">
                <div
                    class="grid grid-cols-2 h-full gap-px bg-border border-x border-border"
                >
                    <div class="bg-background flex items-center px-4">
                        <MdiKeyboardArrowRight /> About
                    </div>
                    <div class="bg-background flex items-center px-4">
                        <MdiKeyboardArrowRight /> Hire me
                    </div>
                    <div class="bg-background flex items-center px-4">
                        <MdiKeyboardArrowRight /> Project
                    </div>
                    <div class="bg-background flex items-center px-4">
                        <MdiKeyboardArrowRight />Contact
                    </div>
                </div>

                <div
                    class="grid grid-cols-2 h-full aspect-square gap-px bg-border"
                >
                    <div class="bg-background flex items-center justify-center">
                        1
                    </div>
                    <div class="bg-background flex items-center justify-center">
                        2
                    </div>
                    <div class="bg-background flex items-center justify-center">
                        3
                    </div>
                    <div class="bg-background flex items-center justify-center">
                        4
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>
